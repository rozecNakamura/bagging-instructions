<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS 上の ASP.NET Core 8 向け（ASP.NET Core モジュール V2 / ANCM）。
  サーバーに「.NET 8.0 ランタイム & Hosting Bundle」をインストールしてください。
  HttpPlatformHandler や Python は不要です。
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore"
             path="*"
             verb="*"
             modules="AspNetCoreModuleV2"
             resourceType="Unspecified" />
      </handlers>
      <!-- ログを有効にする場合はサイト直下に logs フォルダを作成すること -->
      <aspNetCore processPath="dotnet"
                  arguments=".\BaggingInstructions.Api.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <!-- 必要に応じて解除: <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" /> -->
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
